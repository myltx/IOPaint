FROM python:3.10-slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    libsm6 libxext6 ffmpeg libfontconfig1 libxrender1 libgl1 \
    curl gcc build-essential && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip && \
    pip install torch==1.13.1 torchvision==0.14.1 --extra-index-url https://download.pytorch.org/whl/cpu

ARG version
ARG install_plugins=0

RUN (pip install lama-cleaner==$version || pip install lama-cleaner==1.2.5)
RUN pip install "huggingface_hub<0.26"
RUN pip install "numpy<2"
RUN if [ "$install_plugins" = "1" ]; then lama-cleaner --install-plugins-package; fi
ENV LD_PRELOAD=/usr/local/lib/python3.10/site-packages/skimage/_shared/../../scikit_image.libs/libgomp-d22c30c5.so.1.0.0

EXPOSE 8080

CMD ["bash"]
